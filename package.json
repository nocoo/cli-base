{
  "name": "@nocoo/cli-base",
  "version": "0.1.6",
  "description": "Shared CLI infrastructure for hexly.ai projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && biome check src/",
    "lint:fix": "biome check --write src/",
    "prepare": "husky",
    "release": "bun scripts/release.ts"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "picocolors": "^1.1.1",
    "yocto-spinner": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "cli",
    "base",
    "citty",
    "consola"
  ],
  "author": "nocoo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nocoo/cli-base.git"
  }
}
